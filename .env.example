# Server
PORT=3000
NODE_ENV=development

# MongoDB — get a free cluster at mongodb.com/atlas
MONGO_URI="mongodb://localhost:27017/creatuser";
# For Atlas use:
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/campus_lost_found

# JWT (use a long random string in production)
JWT_SECRET=change_this_to_a_long_random_string_in_production

# File upload limit (bytes) — 5 MB default
MAX_FILE_SIZE=5242880

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret


# Nodemailer SMTP Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="Campus Lost & Found" <your-email@gmail.com>

